# Asia Lo Posible — Variables de entorno
# Copia este archivo a .env.local y rellena los valores desde Vaultwarden (vault: Asialoposible)
# NUNCA subas .env.local al repositorio

# ─── Payload CMS ───────────────────────────────────────────────────────────────
# Neon PostgreSQL — usar la cadena SIN pooler (sin -pooler en el hostname)
PAYLOAD_DATABASE_URL=

# Secret aleatorio para JWT signing de Payload (mínimo 32 caracteres)
PAYLOAD_SECRET=

# ─── Vercel Blob (imágenes del blog) ───────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─── Notion CRM ────────────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_LEADS_DATABASE_ID=

# ─── Resend (email transaccional) ──────────────────────────────────────────────
RESEND_API_KEY=

# ID de audiencia para leads del formulario de viaje grupal
RESEND_AUDIENCE_FORM_LEADS=

# ID de audiencia para leads de viajes privados
RESEND_AUDIENCE_PRIVATE_LEADS=

# whsec_... para verificar la firma de webhooks entrantes de Resend
RESEND_WEBHOOK_SECRET=

# Email de fallback para alertas si falla la escritura en Notion
FALLBACK_ALERT_EMAIL=

# ─── WhatsApp Business (via n8n) ───────────────────────────────────────────────
# URL del webhook de n8n que recibe solicitudes de envío de templates
WHATSAPP_WEBHOOK_URL=

# Secret compartido para autenticar el webhook de WhatsApp
WHATSAPP_WEBHOOK_SECRET=
